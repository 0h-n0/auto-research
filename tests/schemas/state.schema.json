{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/0h-n0/auto-research/tests/schemas/state.schema.json",
  "title": "auto-research STATE.json",
  "description": "Schema for .research/<slug>/STATE.json. SoT: skills/auto-research/references/phase_state_machine.md",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_slug",
    "created_at",
    "updated_at",
    "current_phase",
    "last_gate_passed"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "project_slug": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,48}$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "current_phase": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8
    },
    "last_gate_passed": {
      "type": "string",
      "enum": ["G0", "G1", "G2", "G3", "G4"]
    },
    "focus_area": {
      "type": ["string", "null"],
      "enum": [
        "evaluation",
        "agent",
        "post-training",
        "prompt",
        "attention",
        "other",
        null
      ]
    },
    "paper_format": {
      "type": ["string", "null"],
      "enum": ["latex-neurips", "latex-acl", "markdown", null]
    },
    "time_budget_days": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "compute_budget_gpu_h": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "adopted_idea_id": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "active_run_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9]{8}-[0-9]{6}-[0-9a-f]{7}-[0-9a-f]{6}$"
      }
    },
    "completed_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "published": {
      "type": "object",
      "description": "Optional. Set by research.publish skill (v0.6.0+).",
      "additionalProperties": false,
      "properties": {
        "hf_hub": {
          "type": "string",
          "description": "<owner>/<repo> identifier on HuggingFace Hub"
        },
        "zenodo_doi": {
          "type": "string",
          "pattern": "^10\\."
        },
        "zenodo_url": {
          "type": "string",
          "format": "uri"
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "rollbacks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from_phase", "to_phase", "reason", "ts"],
        "properties": {
          "from_phase": {
            "oneOf": [
              {"type": "integer", "minimum": 1, "maximum": 8},
              {"type": "string", "enum": ["G2", "G3", "G4"]}
            ]
          },
          "to_phase": {
            "type": "integer",
            "minimum": 1,
            "maximum": 8
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "ts": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
