{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/0h-n0/auto-research/tests/schemas/metrics.schema.json",
  "title": "auto-research metrics.json",
  "description": "Schema for .research/<slug>/06_RUNS/<run_id>/metrics.json. SoT: skills/research.experiment.run/references/run_id_format.md",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "primary"],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^[0-9]{8}-[0-9]{6}-[0-9a-f]{7}-[0-9a-f]{6}$"
    },
    "primary": {
      "type": "object",
      "required": ["name", "value"],
      "additionalProperties": false,
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "value": {"type": "number"},
        "n": {"type": "integer", "minimum": 0}
      }
    },
    "secondary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "value"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "value": {"type": "number"}
        }
      }
    },
    "per_class": {
      "type": "object"
    },
    "elapsed_seconds": {
      "type": "number",
      "minimum": 0
    },
    "meta": {
      "type": "object",
      "properties": {
        "git_dirty": {"type": "boolean"},
        "cuda_version": {"type": "string"},
        "torch_version": {"type": "string"},
        "gpu": {"type": "string"},
        "num_gpus": {"type": "integer", "minimum": 0}
      }
    },
    "cost_estimate": {
      "type": "object",
      "description": "Optional. Populated by research.cost.estimate skill (v0.5.0+).",
      "additionalProperties": false,
      "required": ["duration_h", "gpu_type", "gpu_count", "estimated_at"],
      "properties": {
        "usd": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Estimated cost in USD. null if gpu_type is unknown."
        },
        "duration_h": {
          "type": "number",
          "minimum": 0
        },
        "gpu_type": {
          "type": "string",
          "description": "Normalized GPU key from gpu_price_table.json"
        },
        "gpu_count": {
          "type": "integer",
          "minimum": 0
        },
        "usd_per_hour": {
          "type": ["number", "null"],
          "minimum": 0
        },
        "pricing_source": {
          "type": "string",
          "description": "Where the unit price came from (e.g. 'AWS p4de', 'user override')"
        },
        "estimated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
